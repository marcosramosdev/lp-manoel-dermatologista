---
import { Image } from 'astro:assets';
import heroImg from '../assets/images/hero.png';

const WHATSAPP = '559985383515';
const WA_MSG = encodeURIComponent(
  'Olá! Vim pelo site e gostaria de agendar uma avaliação dermatológica com o Dr. Manoel Soares.',
);
const WA_LINK = `https://api.whatsapp.com/send?phone=${WHATSAPP}&text=${WA_MSG}&utm_source=site&utm_medium=hero&utm_campaign=agendamento`;

const ADDRESS = 'R. Oscár Galvão, 38 - Centro, Pedreiras - MA, 65725-000';
const MAPS_LINK = `https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(ADDRESS)}`;
---

<section class="min-h-screen pt-16 bg-white flex flex-col md:flex-row overflow-hidden">
  <!-- Texto — lado esquerdo alinhado ao max-w-6xl -->
  <div class="flex-[3] flex items-start py-10 md:py-20 justify-end">
    <div class="w-full max-w-[756px] px-6 md:pr-16">
      <p class="eyebrow mb-3" data-aos="fade-up">Centro Dermatológico</p>

      <h1
        class="text-4xl md:text-5xl lg:text-[3.5rem] font-800 text-ink leading-[1.08] tracking-tight mb-6"
        data-aos="fade-up"
        data-aos-delay="100"
      >
        Avaliação dermatológica para
        <span class="text-brand"> lesões de pele </span>
        com critério médico
      </h1>

      <p class="text-lg text-steel leading-relaxed mb-10 font-300 max-w-xl" data-aos="fade-up" data-aos-delay="200">
        Com 20 anos de atuação em Dermatologia, o Dr. Manoel Soares realiza avaliações clínicas e procedimentos com foco
        em investigação, diagnóstico e tratamento de lesões de pele.
      </p>

      <div class="flex flex-col sm:flex-row gap-3 mb-12" data-aos="fade-up" data-aos-delay="300">
        <a href={WA_LINK} target="_blank" rel="noopener noreferrer" class="btn-primary">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 flex-shrink-0" viewBox="0 0 24 24" fill="currentColor">
            <path
              d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"
            ></path>
          </svg>
          Agendar avaliação
        </a>
        <a href="#avaliacao" class="btn-outline">
          Saiba mais
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
          </svg>
        </a>
      </div>

      <div class="flex flex-wrap gap-x-8 gap-y-3 pt-8 border-t border-rule" data-aos="fade-up" data-aos-delay="400">
        {
          ['Dermatologista', '20 anos de experiência', 'Atendimento individualizado'].map((item) => (
            <div class="flex items-center gap-2 text-sm text-steel font-500">
              <span class="w-1 h-1 bg-brand inline-block flex-shrink-0" />
              {item}
            </div>
          ))
        }
        <div class="flex flex-col sm:flex-row gap-4 mt-8 w-full" data-aos="fade-up">
          <div class="flex items-center gap-4 p-5 border border-rule bg-white flex-1">
            <div class="w-0.5 h-10 bg-brand flex-shrink-0"></div>
            <div>
              <p class="font-600 text-ink text-sm">CRM MA 6497 · RQE 3265</p>
              <p class="text-xs text-steel mt-0.5">Registro profissional ativo</p>
            </div>
          </div>
          <a
            href={MAPS_LINK}
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center gap-4 p-5 border border-rule bg-white flex-1 hover:border-brand transition-colors group"
          >
            <div class="w-0.5 h-10 bg-brand flex-shrink-0"></div>
            <div>
              <p class="font-600 text-ink text-sm group-hover:text-brand transition-colors">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  class="inline h-3.5 w-3.5 mr-1 -mt-0.5"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  stroke-width="2"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
                </svg>
                Pedreiras - MA
              </p>
              <p class="text-xs text-steel mt-0.5">R. Oscár Galvão, 38 · Centro</p>
            </div>
          </a>
        </div>
      </div>
      <span
        class="hidden md:inline-flex mt-10 text-steel/40 hover:text-brand transition-colors"
        aria-label="Rolar para baixo"
        data-aos="fade-up"
        data-aos-delay="500"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="36"
          height="36"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.5"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="animate-bounce"
        >
          <path d="m6 9 6 6 6-6"></path>
        </svg>
      </span>
    </div>
  </div>

  <!-- Imagem — lado direito, bleed até a borda -->
  <div class="h-72 md:h-auto md:flex-[2] md:min-h-full" data-aos="fade-left" data-aos-delay="200">
    <div class="h-full w-full overflow-hidden bg-paper">
      <Image
        src={heroImg}
        alt="Dr. Manoel Soares realizando procedimento dermatológico"
        widths={[390, 560, 840, 1120]}
        sizes="(max-width: 768px) 100vw, 40vw"
        format="webp"
        quality={88}
        class="w-full h-full object-cover object-top"
        loading="eager"
        fetchpriority="high"
      />
    </div>
  </div>
</section>
