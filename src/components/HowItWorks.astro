---
import { MessageCircle, Stethoscope, Microscope, ClipboardCheck, Scissors, CalendarCheck } from 'lucide-react';
const WHATSAPP = '5500000000000';
const WA_MSG = encodeURIComponent('Olá! Gostaria de agendar uma avaliação dermatológica.');
const WA_LINK = `https://wa.me/${WHATSAPP}?text=${WA_MSG}`;

const etapas = [
  { Icon: MessageCircle,  titulo: 'Primeiro contato pelo WhatsApp', descricao: 'A equipe entende sua necessidade, confirma informações básicas e orienta sobre o agendamento.' },
  { Icon: Stethoscope,    titulo: 'Consulta dermatológica', descricao: 'O Dr. Manoel avalia a lesão, a pele e o histórico clínico do paciente.' },
  { Icon: Microscope,     titulo: 'Investigação da lesão', descricao: 'Quando necessário, podem ser indicados exames complementares, dermatoscopia, biópsia ou acompanhamento.' },
  { Icon: ClipboardCheck, titulo: 'Definição da conduta', descricao: 'Após a avaliação, o médico orienta se há necessidade de observação, tratamento clínico, procedimento ou retirada.' },
  { Icon: Scissors,       titulo: 'Procedimento (quando indicado)', descricao: 'Alguns procedimentos podem ser realizados em ambiente ambulatorial. Casos mais complexos podem exigir estrutura específica.' },
  { Icon: CalendarCheck,  titulo: 'Acompanhamento', descricao: 'Pacientes com histórico de lesões podem necessitar de revisões periódicas conforme orientação médica.' },
];
---

<section id="como-funciona" class="py-20 md:py-32 bg-white border-t border-rule">
  <div class="max-w-6xl mx-auto px-6">

    <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-6 mb-12 md:mb-20" data-aos="fade-up">
      <div>
        <p class="eyebrow mb-3">Passo a passo</p>
        <h2 class="text-3xl md:text-4xl font-700 text-ink leading-tight">Como funciona o atendimento</h2>
      </div>
      <a href={WA_LINK} target="_blank" rel="noopener noreferrer" class="btn-primary self-start md:self-auto">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 flex-shrink-0" viewBox="0 0 24 24" fill="currentColor">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
        </svg>
        Agendar minha avaliação
      </a>
    </div>

    <div class="space-y-0 border-t border-rule">
      {etapas.map(({ Icon, titulo, descricao }, i) => (
        <div
          class="grid grid-cols-[3.5rem_1fr] md:grid-cols-[3.5rem_1fr_2fr] gap-6 md:gap-12 py-8 md:py-9 border-b border-rule items-start"
          data-aos="fade-up"
          data-aos-delay={String(i * 80)}
        >
          <div class="flex items-center justify-center w-9 h-9 border border-rule">
            <Icon size={16} className="text-brand" />
          </div>
          <h3 class="text-ink font-600 text-[0.9375rem] leading-snug pt-2">{titulo}</h3>
          <p class="text-steel text-sm leading-relaxed font-300 col-start-2 md:col-start-3 md:pt-2">{descricao}</p>
        </div>
      ))}
    </div>

  </div>
</section>
