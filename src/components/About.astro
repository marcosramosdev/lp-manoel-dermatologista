---
import { Image } from 'astro:assets';
import { BadgeCheck } from 'lucide-react';
import aboutImg from '../assets/images/about.png';

const WHATSAPP = '559985383515';
const WA_MSG = encodeURIComponent(
  'Olá estava olhando o site do doutor e Gostaria de agendar uma avaliação dermatológica.',
);
const WA_LINK = `https://wa.me/${WHATSAPP}?text=${WA_MSG}`;

const diferenciais = [
  'Dermatologista com RQE',
  'Quase 20 anos de experiência em Dermatologia',
  'Foco em cirurgia dermatológica',
  'Experiência com lesões suspeitas e câncer de pele',
  'Atendimento individualizado',
  'Procedimentos indicados conforme necessidade clínica',
  'Acompanhamento de pacientes com histórico de lesões',
];
---

<section id="sobre" class="py-20 md:py-32 bg-paper border-t border-rule">
  <div class="max-w-6xl mx-auto px-6">
    <div class="grid md:grid-cols-5 gap-16 items-start">
      <!-- Foto: entra com fade-up + scale sutil via JS -->
      <div class="md:col-span-2 about-img-col opacity-0">
        <div class="overflow-hidden bg-rule aspect-[3/4]">
          <Image
            src={aboutImg}
            alt="Dr. Manoel Soares, dermatologista"
            width={480}
            height={640}
            class="w-full h-full object-cover object-top about-img-scale"
          />
        </div>
      </div>

      <!-- Texto: cada elemento anima individualmente -->
      <div class="md:col-span-3">
        <p class="eyebrow mb-3" data-aos="fade-up" data-aos-delay="120">Sobre o médico</p>
        <h2 class="text-3xl md:text-4xl font-700 text-ink leading-tight mb-6" data-aos="fade-up" data-aos-delay="200">
          Por que procurar o Dr. Manoel Soares?
        </h2>
        <p class="text-steel font-300 text-[1.0625rem] leading-relaxed mb-10" data-aos="fade-up" data-aos-delay="280">
          O cuidado com lesões de pele exige experiência, atenção aos detalhes e responsabilidade na indicação de cada
          tratamento. Dermatologista com RQE e atuação desde 2007, o Dr. Manoel Soares possui experiência em cirurgia
          dermatológica voltada ao diagnóstico e tratamento de lesões de pele.
        </p>

        <div class="space-y-0 border-t border-rule mb-10">
          {
            diferenciais.map((item, i) => (
              <div
                class="flex items-center gap-3 py-3.5 border-b border-rule"
                data-aos="fade-up"
                data-aos-delay={String(360 + i * 55)}
              >
                <BadgeCheck size={15} className="text-brand flex-shrink-0" />
                <span class="text-ink text-sm">{item}</span>
              </div>
            ))
          }
        </div>

        <div
          class="flex items-center gap-4 p-5 border border-rule bg-white mb-8"
          data-aos="fade-up"
          data-aos-delay={String(360 + diferenciais.length * 55)}
        >
          <div class="w-0.5 h-10 bg-brand flex-shrink-0"></div>
          <div>
            <p class="font-600 text-ink text-sm">CRM MA 6497 · RQE 3265</p>
            <p class="text-xs text-steel mt-0.5">Registro profissional ativo</p>
          </div>
        </div>

        <a
          href={WA_LINK}
          target="_blank"
          rel="noopener noreferrer"
          class="btn-primary"
          data-aos="fade-up"
          data-aos-delay={String(440 + diferenciais.length * 55)}
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 flex-shrink-0" viewBox="0 0 24 24" fill="currentColor">
            <path
              d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"
            ></path>
          </svg>
          Agendar avaliação pelo WhatsApp
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .about-img-col {
    transition:
      opacity 0.9s cubic-bezier(0.22, 1, 0.36, 1),
      transform 0.9s cubic-bezier(0.22, 1, 0.36, 1);
    transform: translateY(24px);
  }
  .about-img-col.is-visible {
    opacity: 1;
    transform: translateY(0);
  }
  .about-img-scale {
    transition: transform 1.1s cubic-bezier(0.22, 1, 0.36, 1);
    transform: scale(1.06);
  }
  .about-img-col.is-visible .about-img-scale {
    transform: scale(1);
  }
  @media (prefers-reduced-motion: reduce) {
    .about-img-col {
      opacity: 1;
      transform: none;
      transition: none;
    }
    .about-img-scale {
      transform: none;
      transition: none;
    }
  }
</style>

<script>
  const col = document.querySelector('.about-img-col');
  if (col) {
    const observer = new IntersectionObserver(
      ([entry]) => {
        if (entry.isIntersecting) {
          col.classList.add('is-visible');
          observer.disconnect();
        }
      },
      { threshold: 0.15 },
    );
    observer.observe(col);
  }
</script>
